// Fisko — Prisma schema.
// Marco 1: User + PasswordResetToken (auth).
// Marco 2 (2A): Invoice + InvoiceItem (DTE SIFEN). A quebra de IVA 5%/10% fica
// como colunas no Invoice (só duas alíquotas) — mais simples para o dashboard.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String? // null se cadastro só via Google
  name          String
  ruc           String? // RUC paraguaio (sem dígito verificador)
  rucDv         Int? // dígito verificador (dDVEmi)
  googleId      String?  @unique
  emailVerified Boolean  @default(false)
  tokenVersion  Int      @default(0) // incrementado no logout para invalidar refresh tokens
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resetTokens      PasswordResetToken[]
  invoices         Invoice[]
  emailConnections EmailConnection[]
}

// Caixa de e-mail conectada para captura automática de DTE (XML em anexos).
// 2C homologação: IMAP com "app password" (Gmail). Produção/Outlook: OAuth.
model EmailConnection {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider     String // gmail | outlook | imap
  email        String
  host         String
  port         Int       @default(993)
  secure       Boolean   @default(true)
  authType     String    @default("app_password") // app_password | oauth (futuro)
  secretEnc    String // senha de app / token cifrado (AES-256-GCM)
  lastSyncAt   DateTime?
  lastSyncInfo String? // resumo (JSON) do último sync
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, email])
  @@index([userId])
}

// DTE SIFEN (Documento Tributário Electrónico) importado pelo usuário.
model Invoice {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cdc            String // Código de Control (44 dígitos) — dedup por usuário (@@unique abaixo)
  tipoDoc        Int // iTiDE: 1=Factura, 4=Autofactura, 5=NC, 6=ND, 7=NR
  tipoDocDesc    String? // dDesTiDE
  emisorRuc      String
  emisorDv       Int?
  emisorNombre   String
  receptorRuc    String?
  receptorDv     Int?
  receptorNombre String?
  fechaEmision   DateTime
  moneda         String   @default("PYG")
  // Totais (gTotSub)
  totalOpe   Decimal @db.Decimal(18, 4) // dTotGralOpe
  totalIva   Decimal @db.Decimal(18, 4) // dTotIVA
  iva5       Decimal @db.Decimal(18, 4) // dIVA5
  iva10      Decimal @db.Decimal(18, 4) // dIVA10
  baseGrav5  Decimal @db.Decimal(18, 4) // dBaseGrav5
  baseGrav10 Decimal @db.Decimal(18, 4) // dBaseGrav10
  // Notas de crédito/débito referenciam o CDC original
  originalCdc String?
  source      String   @default("manual") // manual | email | ocr
  xmlRaw      String?
  createdAt   DateTime @default(now())

  items InvoiceItem[]

  @@unique([userId, cdc])
  @@index([userId])
  @@index([userId, fechaEmision])
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  codigo      String? // dCodInt
  descripcion String // dDesProSer
  cantidad    Decimal @db.Decimal(18, 4) // dCantProSer
  precioUnit  Decimal @db.Decimal(18, 4) // dPUniProSer
  total       Decimal @db.Decimal(18, 4) // dTotOpeItem
  ivaRate     Int // dTasaIVA (0 exento, 5, 10)
  ivaBase     Decimal @db.Decimal(18, 4) // dBasGravIVA
  ivaMonto    Decimal @db.Decimal(18, 4) // dLiqIVAItem

  @@index([invoiceId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String // hash do token (nunca o token em claro)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}
